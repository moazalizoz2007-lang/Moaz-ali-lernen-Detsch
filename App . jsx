                {weakWords.map((w) => (
                  <button key={w.id} className="btn btnSmall" onClick={() => quickFill(w)}>
                    {CATEGORY_ICONS[w.category] ?? "📌"} {stripArticle(w.de) || w.de}
                  </button>
