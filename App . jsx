/** Speech Synthesis (de-DE), stop previous audio before new one */
function useSpeechSynthesis() {
  const utterRef = useRef(null);
  const [state, setState] = useState({ speaking: false, lastText: "" });

  const pickVoice = (lang) => {
    const voices = window.speechSynthesis?.getVoices?.() ?? [];
    const target = (lang || "de-DE").toLowerCase();
    const exact = voices.find((v) => (v.lang || "").toLowerCase() === target);
    if (exact) return exact;
    const prefix = target.split("-")[0];
    const byPrefix = voices.find((v) => (v.lang || "").toLowerCase().startsWith(prefix));
    return byPrefix || null;
  };

  const stop = () => {
    try {
      if (window.speechSynthesis) {
        window.speechSynthesis.cancel();
      }
    } catch {}
    utterRef.current = null;
    setState((s) => ({ ...s, speaking: false }));
  };

  const speak = (text, opts = {}) => {
    const t = normalize(text);
    if (!t) return;

    stop();

    const u = new SpeechSynthesisUtterance(t);
    u.lang = opts.lang || "de-DE";
    u.rate = typeof opts.rate === "number" ? clamp(opts.rate, 0.6, 1.2) : 1.0;
    u.pitch = typeof opts.pitch === "number" ? clamp(opts.pitch, 0.7, 1.2) : 1.0;
    u.volume = typeof opts.volume === "number" ? clamp(opts.volume, 0.0, 1.0) : 1.0;

    const voice = pickVoice(u.lang);
    if (voice) u.voice = voice;

    u.onstart = () => setState({ speaking: true, lastText: t });
    u.onend = () => setState((s) => ({ ...s, speaking: false }));
    u.onerror = () => setState((s) => ({ ...s, speaking: false }));

    utterRef.current = u;
    try {
      window.speechSynthesis.speak(u);
    } catch {
      setState((s) => ({ ...s, speaking: false }));
    }
  };

  return { ...state, speak, stop };
}

/** Teacher engine (simulated logic) */
function parseArticle(deWord) {
  const s = toLowerDe(deWord);
  if (s.startsWith("der ")) return "der";
  if (s.startsWith("die ")) return "die";
  if (s.startsWith("das ")) return "das";
  return null;
}

function stripArticle(deWord) {
  const s = normalize(deWord);
  const low = toLowerDe(s);
  if (low.startsWith("der ")) return s.slice(4);
  if (low.startsWith("die ")) return s.slice(4);
  if (low.startsWith("das ")) return s.slice(4);
  return s;
}

function teacherEngine(text, words) {
  const t = normalize(text);

  const vocabIndex = words.map((w) => ({
    id: w.id,
    de: normalize(w.de),
    deLow: toLowerDe(w.de),
    bare: normalize(stripArticle(w.de)),
    bareLow: toLowerDe(stripArticle(w.de)),
    article: parseArticle(w.de),
    category: w.category,
    difficulty: w.difficulty,
  }));

  const detectedWords = [];
  const textLow = toLowerDe(t);

  for (const v of vocabIndex) {
    if (!v.bareLow) continue;
    const re = new RegExp(`\\b${escapeRegExp(v.bareLow)}\\b`, "i");
    if (re.test(textLow) || new RegExp(`\\b${escapeRegExp(v.deLow)}\\b`, "i").test(textLow)) {
      const w = words.find((x) => x.id === v.id);
      if (w) detectedWords.push(w);
    }
  }

  const issues = [];

  // A1 core patterns
  const hasIch = /\bich\b/i.test(t);
  const hasDu = /\bdu\b/i.test(t);
  const hasWir = /\bwir\b/i.test(t);
  const hasBin = /\bbin\b/i.test(textLow);
  const hasBist = /\bbist\b/i.test(textLow);
  const hasSind = /\bsind\b/i.test(textLow);

  // Common A1: "Ich bin ..." / "Du bist ..." / "Wir sind ..."
  if ((hasIch && !hasBin && /\bich\b/i.test(t)) && /\bsein\b/i.test(textLow) === false && /\bbin\b/i.test(textLow) === false) {
    // no direct issue; allow other verbs
  }

  // Detect common wrong article usage: "Ich habe der Apfel." etc.
  // Heuristic: after "habe" / "hast" / "haben" expect Akkusativ article (den/die/das/einen/eine).
  const haveMatch = textLow.match(/\b(ich|du|wir|sie|er|ihr)\s+(habe|hast|haben|hat)\b/);
  if (haveMatch) {
    const after = textLow.split(haveMatch[0])[1] || "";
    const hasWrongNomArticle = /\b(der|die|das)\b/.test(after);
    const hasAccArticle = /\b(den|die|das|einen|eine)\b/.test(after);
    if (hasWrongNomArticle && !hasAccArticle) {
      issues.push({
        type: "artikel",
        severity: "warn",
        code: "AKK_NACH_HABEN",
        message: "Nach „haben“ oft Akkusativ: den/die/das oder einen/eine.",
      });
    }
  }

  // Specific word article correctness if noun present with wrong article
  for (const v of vocabIndex) {
    if (!v.article) continue;
    const noun = v.bareLow;
    if (!noun) continue;

    // If noun occurs, check nearby "der/die/das" before noun
    const pattern = new RegExp(`\\b(der|die|das)\\s+${escapeRegExp(noun)}\\b`, "i");
    const m = textLow.match(pattern);
    if (m) {
      const used = m[1].toLowerCase();
      if (used !== v.article) {
        issues.push({
          type: "artikel",
          severity: "error",
          code: "ARTIKEL_FALSCH",
          message: `Artikel passt nicht: ${used} ${stripArticle(v.de)} → richtig: ${v.article} ${stripArticle(v.de)}.`,
          fix: (s) => s.replace(new RegExp(`\\b${used}\\s+${escapeRegExp(stripArticle(v.de))}\\b`, "i"), `${v.article} ${stripArticle(v.de)}`),
        });
      }
    }
  }

  // Word order hint: verb in position 2 for simple main clauses
  // If sentence starts with "Heute" or time adverb, ensure second token is verb (very heuristic)
  if (/^\s*(heute|morgen|jetzt)\b/i.test(t)) {
    const tokens = t.split(/\s+/).filter(Boolean);
    if (tokens.length >= 3) {
      // naive: token[1] should often be verb
      const second = toLowerDe(tokens[1]);
      const isLikelyVerb = /(bin|bist|ist|sind|seid|haben|habe|hast|hat|gehen|gehe|gehst|geht|lernen|lerne|lernst|lernt|kaufen|kaufe|kaufst|kauft)/.test(
        second
      );
      if (!isLikelyVerb) {
        issues.push({
          type: "wortstellung",
          severity: "warn",
          code: "VERB_ZWEIT",
          message: "Im Hauptsatz steht das Verb oft an Position 2.",
        });
      }
    }
  }

  // Detect missing punctuation (A1): encourage a dot.
  if (t && !/[.!?]$/.test(t)) {
    issues.push({
      type: "satzzeichen",
      severity: "warn",
      code: "PUNKT",
      message: "Am Ende: Punkt, Fragezeichen oder Ausrufezeichen.",
      fix: (s) => s + ".",
    });
  }

  // Detect too-long sentence for A1 training
  const wordCount = t ? t.split(/\s+/).filter(Boolean).length : 0;
  if (wordCount > 12) {
    issues.push({
      type: "niveau",
      severity: "warn",
      code: "A1_KURZ",
      message: "A1: kurze Sätze (ca. 6–12 Wörter) sind leichter.",
    });
  }

  // Minimal empty detection
  if (!t) {
    issues.push({
      type: "leer",
      severity: "error",
      code: "LEER",
      message: "Bitte einen Satz schreiben.",
    });
  }

  const severity = issues.some((i) => i.severity === "error") ? "error" : issues.length ? "warn" : "ok";

  // Build correction proposal
  let correction = t;
  for (const issue of issues) {
    if (typeof issue.fix === "function") {
      correction = issue.fix(correction);
    }
  }
  correction = normalize(correction);

  // Example generation (A1)
  const example = buildA1Example(detectedWords, words);

  // Hint (stepwise)
  const hint = buildHint(issues, detectedWords);

  // Explanation behavior
  const explanation = buildExplanation(issues);

  return {
    input: t,
    detectedWords,
    issues,
    severity,
    correction: correction && correction !== t ? correction : null,
    example,
    hint,
    explanation,
  };
}

function teacherRespond(analysis, mode) {
  const { severity, issues, correction, example, hint, explanation, input } = analysis;

  if (mode === "beispiele") {
    const ex = example || "Ich lerne Deutsch.";
    return {
      title: severity === "error" ? "Beispiel" : "Beispiel",
      tone: "A1",
      message: `Hier ist ein kurzes Beispiel:`,
      example: ex,
      listenText: ex,
      speak: ex,
    };
  }

  if (mode === "hinweis") {
    if (!input) {
      return {
        title: "Hinweis",
        tone: "Start",
        message: "Schreibe einen einfachen Satz, z.B. „Ich bin müde.“ oder „Ich habe das Brot.“",
        hint: "Tipp: Subjekt + Verb + Objekt.",
        listenText: "Ich habe das Brot.",
        speak: "Ich habe das Brot.",
      };
    }
    const h = hint || "Tipp: Verb an Position 2.";
    return {
      title: "Hinweis",
      tone: severity === "error" ? "streng" : "freundlich",
      message: "Ich gebe dir einen Hinweis, ohne alles zu verraten:",
      hint: h,
      example: example || "Ich habe das Wasser.",
      listenText: h,
      speak: null,
    };
  }

  // korrektur
  if (!input) {
    return {
      title: "Korrektur",
      tone: "Start",
      message: "Schreibe einen Satz, dann korrigiere ich ihn.",
      correction: null,
      explanation: null,
      hint: "Beispiel: „Ich habe den Apfel.“",
      example: "Ich habe den Apfel.",
      listenText: "Ich habe den Apfel.",
      speak: null,
    };
  }

  if (severity === "ok") {
    return {
      title: "Sehr gut",
      tone: "positiv",
      message: "Der Satz ist gut. Weiter so.",
      correction: null,
      explanation: "Keine Fehler erkannt.",
      hint: "Tipp: Variiere mit „Heute“, „Jetzt“, „Morgen“.",
      example: example || "Heute lerne ich Deutsch.",
      listenText: input,
      speak: input,
    };
  }

  const topIssue = issues[0];
  const title = severity === "error" ? "Korrektur" : "Fast richtig";
  const tone = severity === "error" ? "streng" : "freundlich";

  return {
    title,
    tone,
    message:
      severity === "error"
        ? `Ich sehe einen wichtigen Fehler: ${topIssue.message}`
        : `Ich sehe eine kleine Sache: ${topIssue.message}`,
    correction: correction || input,
    explanation: explanation || "Regel: kurz und klar.",
    hint: hint || "Tipp: Artikel prüfen.",
    example: example || "Ich habe das Brot.",
    listenText: correction || input,
    speak: correction || input,
  };
}

function buildA1Example(detectedWords, allWords) {
  const pick = (arr) => (arr.length ? arr[Math.floor(Math.random() * arr.length)] : null);
  const w = pick(detectedWords) || pick(allWords);
  if (!w) return "Ich lerne Deutsch.";

  const article = parseArticle(w.de);
  const noun = stripArticle(w.de);

  const isVerbPhrase = !article && /\b(ich|du|wir|sie|er|ihr)\b/i.test(w.de);

  if (isVerbPhrase) {
    return `${capitalizeFirst(w.de)}.`;
  }

  if (article) {
    const bare = noun;
    if (article === "der") return `Ich habe den ${bare}.`;
    if (article === "die") return `Ich habe die ${bare}.`;
    if (article === "das") return `Ich habe das ${bare}.`;
  }

  return `Ich lerne ${w.de}.`;
}

function buildHint(issues, detectedWords) {
  if (!issues.length) {
    if (detectedWords.length) {
      const w = detectedWords[0];
      const art = parseArticle(w.de);
      const noun = stripArticle(w.de);
      if (art) return `Tipp: Der Artikel ist „${art}“ bei „${noun}“.`;
    }
    return "Tipp: Subjekt + Verb + Objekt.";
  }

  const codes = issues.map((i) => i.code);
  if (codes.includes("ARTIKEL_FALSCH")) return "Tipp: Prüfe den Artikel (der/die/das) beim Nomen.";
  if (codes.includes("AKK_NACH_HABEN")) return "Tipp: Nach „haben“ oft Akkusativ: den/die/das (oder einen/eine).";
  if (codes.includes("VERB_ZWEIT")) return "Tipp: Im Hauptsatz steht das Verb oft an Position 2.";
  if (codes.includes("PUNKT")) return "Tipp: Setze am Ende einen Punkt.";
  if (codes.includes("A1_KURZ")) return "Tipp: Mach den Satz kürzer (A1).";
  if (codes.includes("LEER")) return "Tipp: Schreibe einen Satz, z.B. „Ich habe das Wasser.“";
  return "Tipp: Einfacher Satz: Subjekt + Verb + Objekt.";
}

function buildExplanation(issues) {
  if (!issues.length) return "Keine Fehler erkannt.";
  const parts = [];
  const uniq = new Set();
  for (const i of issues) {
    if (uniq.has(i.code)) continue;
    uniq.add(i.code);
    if (i.code === "AKK_NACH_HABEN") parts.push("Nach „haben“ benutzt man oft Akkusativ (den/die/das).");
    else if (i.code === "ARTIKEL_FALSCH") parts.push("Artikel gehören zum Nomen und müssen passen (der/die/das).");
    else if (i.code === "VERB_ZWEIT") parts.push("Im Hauptsatz steht das Verb oft an zweiter Stelle.");
    else if (i.code === "PUNKT") parts.push("Satzzeichen am Ende machen den Satz klar.");
    else if (i.code === "A1_KURZ") parts.push("Kurze Sätze sind auf A1 leichter.");
    else if (i.code === "LEER") parts.push("Ohne Satz kann ich nichts korrigieren.");
    else parts.push(i.message);
  }
  return parts.join(" ");
}

function escapeRegExp(s) {
  return (s ?? "").replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
}

function capitalizeFirst(s) {
  const t = normalize(s);
  if (!t) return t;
  return t[0].toLocaleUpperCase("de-DE") + t.slice(1);
}

