                <div className="notice">
                  <Sparkles className="noticeIcon" />
                  <div>
                    Simulation: <strong>Gemeistert</strong> erhöht Meisterung stark, <strong>Wiederholen</strong> senkt leicht.
                    XP wird vergeben.
                  </div>
                </div>
              </div>
            </div>
          </div>
        )}
