          <button className="btn btnSmall btnPrimary" onClick={() => setRoute("quiz")}>
            <Swords className="navIcon" /> Start
          </button>
          <button className="btn btnSmall" onClick={() => setRoute("flashcards")}>
            <Repeat2 className="navIcon" /> Karten
          </button>
          <button className="btn btnSmall" onClick={() => setRoute("teacher")}>
            <Brain className="navIcon" /> Lehrer
          </button>
        </div>
      </div>

      <div className="grid">
        <div className="grid2">
          <div className="card">
            <div className="cardPad">
              <div className="cardTitle">
                <h3>Fortschritt</h3>
                <div className="muted">Stufe {level.current.key}</div>
              </div>
              <div className="row" style={{ alignItems: "flex-end", gap: 16 }}>
                <div className="kpi">
                  <div className="kpiLabel">XP</div>
                  <div className="kpiValue">
                    {progress.xp} <small>gesamt</small>
                  </div>
                </div>
                <div className="kpi">
                  <div className="kpiLabel">Serie</div>
                  <div className="kpiValue">
                    {progress.streak.count} <small>Tage</small>
                  </div>
                </div>
                <div className="kpi">
                  <div className="kpiLabel">Treffer</div>
                  <div className="kpiValue">
                    {acc}% <small>Quote</small>
                  </div>
                </div>
              </div>
              <div style={{ height: 14 }} />
              <div className="row" style={{ justifyContent: "space-between" }}>
                <div className="subText">
                  {level.current.key} → {level.next.key}
                </div>
                <div className="subText">{level.pct}%</div>
              </div>
              <div className="progressBar">
                <div className="progressFill" style={{ width: `${level.pct}%` }} />
              </div>
              <div style={{ height: 12 }} />
              <div className="row" style={{ gap: 8 }}>
                <span className="tag">
                  <CheckCircle2 style={{ width: 16, height: 16 }} /> <strong>{masteredCount}</strong>{" "}
                  <span>gemeistert</span>
                </span>
                <span className="tag">
                  <Lightbulb style={{ width: 16, height: 16 }} /> <strong>{weakCount}</strong>{" "}
                  <span>schwach</span>
                </span>
                <span className="tag">
                  <BookOpen style={{ width: 16, height: 16 }} /> <strong>{filteredWords.length}</strong>{" "}
                  <span>im Filter</span>
                </span>
              </div>
            </div>
          </div>

          <div className="card">
            <div className="cardPad">
              <div className="cardTitle">
                <h3>Nächste Ziele</h3>
                <div className="muted">fokus</div>
              </div>
              <div className="list">
                {nextTargets.map(({ w, m }) => (
                  <div
                    key={w.id}
                    style={{
                      display: "flex",
                      alignItems: "center",
                      gap: 12,
                      border: "1px solid var(--border)",
