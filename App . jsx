                </div>

                <div className="row" style={{ justifyContent: "space-between" }}>
                  <div className="row">
                    <button
                      className="btn"
                      onClick={() => setFlashState((s) => ({ ...s, index: clamp(s.index - 1, 0, flashList.length - 1) }))}
                      disabled={currentIndex <= 0}
