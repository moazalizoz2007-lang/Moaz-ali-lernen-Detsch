    addWord({ de, ar, image, category, difficulty });
    setStatus({ type: "ok", message: "Wort hinzugefügt." });
    setForm((f) => ({ ...f, de: "", ar: "", image: "" }));
    setTimeout(() => setStatus({ type: "idle", message: "" }), 1400);
