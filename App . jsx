function AddWordCard() {
  const { addWord, categories } = useContext(AppContext);
  const [form, setForm] = useState({
    de: "",
    ar: "",
    image: "",
    category: categories.includes("Alltag") ? "Alltag" : "Alltag",
    difficulty: "A1",
  });

  const [status, setStatus] = useState({ type: "idle", message: "" });

  const validateImageUrl = (url) => {
    try {
      const u = new URL(url);
      return ["http:", "https:"].includes(u.protocol);
    } catch {
      return false;
    }
  };

  const submit = () => {
    const de = normalize(form.de);
    const ar = normalize(form.ar);
    const image = normalize(form.image);
    const category = normalize(form.category);
    const difficulty = form.difficulty;

    if (!de || !ar || !image || !category || !difficulty) {
      setStatus({ type: "error", message: "Bitte alle Felder ausfüllen." });
      return;
    }
    if (!validateImageUrl(image)) {
      setStatus({ type: "error", message: "Bild-URL ungültig." });
      return;
    }
    if (!DIFFICULTY_ORDER.includes(difficulty)) {
      setStatus({ type: "error", message: "Niveau ungültig." });
      return;
