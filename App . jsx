function Dashboard() {
  const { progress, words, level, setRoute, filteredWords } = useContext(AppContext);

  const masteredCount = useMemo(
    () => words.filter((w) => (progress.masteryById[w.id] ?? 0) >= 80).length,
    [words, progress.masteryById]
  );

  const weakCount = useMemo(
    () => words.filter((w) => (progress.masteryById[w.id] ?? 0) <= 30).length,
    [words, progress.masteryById]
  );

  const acc = progress.sessions.totalAnswers
    ? Math.round((progress.sessions.correctAnswers / progress.sessions.totalAnswers) * 100)
    : 0;

  const nextTargets = useMemo(() => {
    const ranked = words
      .map((w) => {
        const m = progress.masteryById[w.id] ?? 0;
        const wrong = progress.statsById[w.id]?.wrong ?? 0;
        const correct = progress.statsById[w.id]?.correct ?? 0;
        const lastSeenAt = progress.statsById[w.id]?.lastSeenAt ?? 0;
        const recency = clamp((Date.now() - lastSeenAt) / (5 * 24 * 3600 * 1000), 0, 1);
        const need = (100 - m) / 100;
        const err = clamp((wrong + 1) / (correct + wrong + 2), 0, 1);
        const score = need * 0.65 + err * 0.25 + recency * 0.10;
        return { w, score, m };
      })
      .sort((a, b) => b.score - a.score)
      .slice(0, 4);
    return ranked;
  }, [words, progress.masteryById, progress.statsById]);

  return (
    <>
      <div className="contentHeader">
        <div>
          <h2>Übersicht</h2>
          <div className="subText">XP · Serie · Meisterung · Nächste Ziele</div>
        </div>
