function Teacher() {
  const { words, progress, speech } = useContext(AppContext);

  const [input, setInput] = useState("");
  const [mode, setMode] = useState("korrektur"); // korrektur | beispiele | hinweis
  const [result, setResult] = useState(null);

  const weakWords = useMemo(() => {
    return words
      .map((w) => ({ w, m: progress.masteryById[w.id] ?? 0 }))
      .sort((a, b) => a.m - b.m)
      .slice(0, 6)
      .map((x) => x.w);
  }, [words, progress.masteryById]);

  const analyze = () => {
    const text = normalize(input);
    const analysis = teacherEngine(text, words);
    const output = teacherRespond(analysis, mode);
    setResult({ analysis, output });
    if (output?.speak) {
      speech.speak(output.speak, { lang: "de-DE", rate: 0.96 });
