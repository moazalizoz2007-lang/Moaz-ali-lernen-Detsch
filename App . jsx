const createInitialProgress = (words) => {
  const masteryById = {};
  const statsById = {};
  for (const w of words) {
    masteryById[w.id] = 0; // 0..100
    statsById[w.id] = { correct: 0, wrong: 0, lastSeenAt: 0, lastResult: null };
  }
  return { masteryById, statsById };
};

function App() {
  const [theme, setTheme] = useState("dark");
  const [route, setRoute] = useState("dashboard"); // dashboard | vocab | flashcards | quiz | teacher
  const [words, setWords] = useState(seedWords);

  const [progress, setProgress] = useState(() => ({
    xp: 0,
    streak: { count: 0, lastStudyDay: null },
    ...createInitialProgress(seedWords),
    sessions: { totalAnswers: 0, correctAnswers: 0 },
  }));

  const [filters, setFilters] = useState({
    category: "Alle",
    difficulty: "Alle",
    query: "",
  });

  const [flashState, setFlashState] = useState({
    index: 0,
    mode: "alle", // alle | wiederholen | gemeistert
  });

  const [quizState, setQuizState] = useState(() => ({
    running: false,
    type: 1, // 1 or 2
    current: null,
    questionId: null,
    selected: null,
    revealed: false,
    correct: null,
    score: 0,
    total: 0,
    lastDeltaXp: 0,
    lastMasteryDelta: 0,
    lastWordId: null,
    seed: uid(),
  }));

  const speech = useSpeechSynthesis();

  const level = useMemo(() => {
    const xp = progress.xp;
    let current = LEVELS[0];
    for (const lv of LEVELS) if (xp >= lv.minXp) current = lv;
    const nextIdx = Math.min(LEVELS.length - 1, LEVELS.findIndex((l) => l.key === current.key) + 1);
    const next = LEVELS[nextIdx];
    const nextMin = next.minXp;
    const currentMin = current.minXp;
    const range = Math.max(1, nextMin - currentMin);
    const pct = clamp(Math.round(((xp - currentMin) / range) * 100), 0, 100);
    return { current, next, pct };
  }, [progress.xp]);

  const categories = useMemo(() => {
    const set = new Set(words.map((w) => w.category));
    return ["Alle", ...Array.from(set).sort((a, b) => a.localeCompare(b, "de"))];
  }, [words]);

  const difficulties = useMemo(() => ["Alle", ...DIFFICULTY_ORDER], []);

  const filteredWords = useMemo(() => {
    const q = toLowerDe(filters.query);
    return words
      .filter((w) => (filters.category === "Alle" ? true : w.category === filters.category))
      .filter((w) => (filters.difficulty === "Alle" ? true : w.difficulty === filters.difficulty))
      .filter((w) => {
        if (!q) return true;
        const hay = toLowerDe([w.de, w.ar, w.category, w.difficulty, ...(w.tags || [])].join(" "));
        return hay.includes(q);
      });
  }, [words, filters]);

  const studyDayKey = useMemo(() => {
    const d = new Date();
    const y = d.getFullYear();
    const m = String(d.getMonth() + 1).padStart(2, "0");
    const day = String(d.getDate()).padStart(2, "0");
    return `${y}-${m}-${day}`;
  }, []);

  const ensureStreakForToday = () => {
    setProgress((p) => {
      const last = p.streak.lastStudyDay;
      if (last === studyDayKey) return p;

      if (!last) {
        return { ...p, streak: { count: 1, lastStudyDay: studyDayKey } };
      }
      const lastDate = new Date(last + "T00:00:00");
      const todayDate = new Date(studyDayKey + "T00:00:00");
      const diffDays = Math.round((todayDate.getTime() - lastDate.getTime()) / (24 * 3600 * 1000));
      if (diffDays === 1) {
        return { ...p, streak: { count: p.streak.count + 1, lastStudyDay: studyDayKey } };
      }
      return { ...p, streak: { count: 1, lastStudyDay: studyDayKey } };
    });
  };

  const awardForAnswer = ({ wordId, isCorrect, mode }) => {
    ensureStreakForToday();

    const baseXp = isCorrect ? 14 : 4;
    const speedBonus = mode === "quiz" && isCorrect ? 2 : 0;
    const masteryDelta = isCorrect ? 12 : -8;

    setProgress((p) => {
      const prevMastery = p.masteryById[wordId] ?? 0;
      const nextMastery = clamp(prevMastery + masteryDelta, 0, 100);

      const stats = p.statsById[wordId] ?? { correct: 0, wrong: 0, lastSeenAt: 0, lastResult: null };
      const now = Date.now();
      const nextStats = {
        ...stats,
        correct: stats.correct + (isCorrect ? 1 : 0),
        wrong: stats.wrong + (isCorrect ? 0 : 1),
        lastSeenAt: now,
        lastResult: isCorrect ? "richtig" : "falsch",
      };

      const nextTotal = p.sessions.totalAnswers + 1;
      const nextCorrect = p.sessions.correctAnswers + (isCorrect ? 1 : 0);

      return {
        ...p,
        xp: p.xp + baseXp + speedBonus,
        masteryById: { ...p.masteryById, [wordId]: nextMastery },
        statsById: { ...p.statsById, [wordId]: nextStats },
        sessions: { totalAnswers: nextTotal, correctAnswers: nextCorrect },
      };
    });

    setQuizState((qs) => ({
      ...qs,
      lastDeltaXp: baseXp + speedBonus,
      lastMasteryDelta: masteryDelta,
      lastWordId: wordId,
    }));
  };

  const pickFlashList = useMemo(() => {
    const all = filteredWords.length ? filteredWords : words;
    const mastered = all.filter((w) => (progress.masteryById[w.id] ?? 0) >= 80);
    const repeat = all.filter((w) => (progress.masteryById[w.id] ?? 0) < 80);

    if (flashState.mode === "gemeistert") return mastered.length ? mastered : all;
    if (flashState.mode === "wiederholen") return repeat.length ? repeat : all;
    return all;
  }, [filteredWords, words, progress.masteryById, flashState.mode]);

  const flashWord = pickFlashList[clamp(flashState.index, 0, Math.max(0, pickFlashList.length - 1))] ?? null;

  const startQuiz = (type) => {
    setQuizState((qs) => {
      const next = {
        ...qs,
        running: true,
        type,
        current: null,
        questionId: uid(),
        selected: null,
        revealed: false,
        correct: null,
        score: 0,
        total: 0,
        seed: uid(),
        lastDeltaXp: 0,
        lastMasteryDelta: 0,
        lastWordId: null,
      };
      return next;
    });
    nextQuestion(type);
  };

  const buildQuestion = (type) => {
    const pool = filteredWords.length ? filteredWords : words;
    const candidates = pool.length >= 4 ? pool : words;
    const weighted = candidates.map((w) => {
      const m = progress.masteryById[w.id] ?? 0;
      const wrong = progress.statsById[w.id]?.wrong ?? 0;
      const correct = progress.statsById[w.id]?.correct ?? 0;
      const lastSeenAt = progress.statsById[w.id]?.lastSeenAt ?? 0;
      const recencyPenalty = Math.min(0.6, (Date.now() - lastSeenAt) / (7 * 24 * 3600 * 1000));
      const need = (100 - m) / 100;
      const err = clamp((wrong + 1) / (correct + wrong + 2), 0, 1);
      const difficultyBoost = (DIFFICULTY_ORDER.indexOf(w.difficulty) + 1) / DIFFICULTY_ORDER.length;
      const weight = 0.25 + 0.55 * need + 0.15 * err + 0.05 * difficultyBoost + 0.1 * recencyPenalty;
      return { w, weight };
    });

    const totalWeight = weighted.reduce((s, x) => s + x.weight, 0);
    let r = Math.random() * totalWeight;
    let chosen = weighted[0]?.w ?? (candidates[0] ?? words[0]);
    for (const x of weighted) {
      r -= x.weight;
      if (r <= 0) {
        chosen = x.w;
        break;
      }
    }

    const distractorPool = candidates.filter((x) => x.id !== chosen.id);
    const distractors = shuffle(distractorPool).slice(0, 3);
    const options = shuffle([chosen, ...distractors]).map((w) => ({ id: w.id, label: w.de }));

    return {
      id: uid(),
      type,
      wordId: chosen.id,
      promptImage: type === 1 ? chosen.image : null,
      promptAudio: type === 2 ? chosen.de : null,
      options,
      answerId: chosen.id,
      meta: {
        category: chosen.category,
        difficulty: chosen.difficulty,
      },
    };
  };

  const nextQuestion = (forceType) => {
    setQuizState((qs) => {
      const type = forceType ?? qs.type ?? 1;
      const q = buildQuestion(type);
      return {
        ...qs,
        running: true,
        type,
        current: q,
        questionId: q.id,
        selected: null,
        revealed: false,
        correct: null,
      };
    });
  };

  const answerQuiz = (optionId) => {
    setQuizState((qs) => {
      if (!qs.current || qs.revealed) return qs;
      const isCorrect = optionId === qs.current.answerId;
      return {
        ...qs,
        selected: optionId,
        revealed: true,
        correct: isCorrect,
        score: qs.score + (isCorrect ? 1 : 0),
        total: qs.total + 1,
      };
    });

    const wordId = quizState.current?.wordId;
    const answerId = quizState.current?.answerId;
    const isCorrect = optionId === answerId;
    if (wordId) awardForAnswer({ wordId, isCorrect, mode: "quiz" });
  };

  const stopQuiz = () => {
    setQuizState((qs) => ({
      ...qs,
      running: false,
      current: null,
      selected: null,
      revealed: false,
      correct: null,
    }));
    speech.stop();
  };

  const addWord = ({ de, ar, image, category, difficulty }) => {
    const newWord = {
      id: uid(),
      de: normalize(de),
      ar: normalize(ar),
      image: normalize(image),
      category: normalize(category),
      difficulty: difficulty,
      tags: [],
    };

    setWords((w) => [newWord, ...w]);
    setProgress((p) => ({
      ...p,
      masteryById: { ...p.masteryById, [newWord.id]: 0 },
      statsById: {
        ...p.statsById,
        [newWord.id]: { correct: 0, wrong: 0, lastSeenAt: 0, lastResult: null },
      },
    }));
  };

  const ctx = useMemo(
    () => ({
      theme,
      setTheme,
      route,
      setRoute,
      words,
      setWords,
      progress,
      setProgress,
      filters,
      setFilters,
      categories,
      difficulties,
      filteredWords,
      flashState,
      setFlashState,
      flashWord,
      flashList: pickFlashList,
      quizState,
      setQuizState,
      startQuiz,
      nextQuestion,
      answerQuiz,
      stopQuiz,
      addWord,
      speech,
      level,
    }),
    [
      theme,
      route,
      words,
      progress,
      filters,
      categories,
      difficulties,
      filteredWords,
      flashState,
      flashWord,
      pickFlashList,
      quizState,
      speech,
      level,
    ]
  );

  return (
    <AppContext.Provider value={ctx}>
      <div className={theme === "dark" ? "app dark" : "app light"}>
        <Style />
        <TopHeader />
        <MainLayout />
      </div>
    </AppContext.Provider>
  );
}

