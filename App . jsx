function Flashcards() {
  const { flashWord, flashState, setFlashState, flashList, progress, speech } = useContext(AppContext);

  const currentIndex = clamp(flashState.index, 0, Math.max(0, flashList.length - 1));
  const current = flashWord;

  const mark = (kind) => {
    if (!current) return;
    if (kind === "mastered") {
      // simulate: mark as correct with bonus
      awardFlash(current.id, true);
    } else {
      awardFlash(current.id, false);
    }
    setFlashState((s) => ({ ...s, index: clamp(s.index + 1, 0, Math.max(0, flashList.length - 1)) }));
  };

  const awardFlash = (wordId, isCorrect) => {
    // flash uses same engine but smaller deltas to simulate spaced repetition
    const baseXp = isCorrect ? 8 : 3;
    const masteryDelta = isCorrect ? 10 : -6;

    // streak + mastery + stats
    // implemented here to keep logic strict and self-contained
    const studyDayKey = (() => {
      const d = new Date();
      const y = d.getFullYear();
      const m = String(d.getMonth() + 1).padStart(2, "0");
      const day = String(d.getDate()).padStart(2, "0");
      return `${y}-${m}-${day}`;
    })();

    // local helper: keep SpeechSynthesis clean while interacting
    speech.stop();

    // update progress
    const { setProgress } = useContext(AppContext);
    setProgress((p) => {
      const last = p.streak.lastStudyDay;
      let nextStreak = p.streak;
      if (last !== studyDayKey) {
        if (!last) nextStreak = { count: 1, lastStudyDay: studyDayKey };
        else {
          const lastDate = new Date(last + "T00:00:00");
          const todayDate = new Date(studyDayKey + "T00:00:00");
          const diffDays = Math.round((todayDate.getTime() - lastDate.getTime()) / (24 * 3600 * 1000));
          nextStreak = diffDays === 1 ? { count: p.streak.count + 1, lastStudyDay: studyDayKey } : { count: 1, lastStudyDay: studyDayKey };
        }
      }

      const prevMastery = p.masteryById[wordId] ?? 0;
      const nextMastery = clamp(prevMastery + masteryDelta, 0, 100);

      const stats = p.statsById[wordId] ?? { correct: 0, wrong: 0, lastSeenAt: 0, lastResult: null };
      const now = Date.now();
      const nextStats = {
        ...stats,
        correct: stats.correct + (isCorrect ? 1 : 0),
        wrong: stats.wrong + (isCorrect ? 0 : 1),
        lastSeenAt: now,
        lastResult: isCorrect ? "richtig" : "falsch",
      };

      const nextTotal = p.sessions.totalAnswers + 1;
      const nextCorrect = p.sessions.correctAnswers + (isCorrect ? 1 : 0);

      return {
        ...p,
        xp: p.xp + baseXp,
        streak: nextStreak,
        masteryById: { ...p.masteryById, [wordId]: nextMastery },
        statsById: { ...p.statsById, [wordId]: nextStats },
        sessions: { totalAnswers: nextTotal, correctAnswers: nextCorrect },
      };
    });
  };

  const mastery = current ? progress.masteryById[current.id] ?? 0 : 0;

  return (
    <>
      <div className="contentHeader">
        <div>
          <h2>Karten</h2>
          <div className="subText">Bild · Wort · Übersetzung · Wiederholung</div>
        </div>

        <div className="row">
          <span className="tag">
            <Repeat2 style={{ width: 16, height: 16 }} />
            <strong>{flashList.length}</strong>
            <span>Karten</span>
          </span>

          <select
            className="select"
            style={{ width: 190 }}
            value={flashState.mode}
            onChange={(e) => setFlashState((s) => ({ ...s, mode: e.target.value, index: 0 }))}
          >
            <option value="alle">alle</option>
            <option value="wiederholen">wiederholen</option>
            <option value="gemeistert">gemeistert</option>
          </select>
        </div>
      </div>

      <div className="grid">
        {!current ? (
          <div className="notice">
            <Lightbulb className="noticeIcon" />
            <div>Keine Karten verfügbar.</div>
          </div>
        ) : (
          <div className="flashWrap">
            <div className="flashCard">
              <div className="flashTop">
                <img className="flashImg" src={current.image} alt={current.de} />
                <div className="flashOverlay">
                  <div className="flashOverlayInner">
                    <div>
                      <div className="flashWord">{current.de}</div>
                      <div className="flashSub">
                        {CATEGORY_ICONS[current.category] ?? "📌"} {current.category} · {current.difficulty}
                      </div>
                    </div>
                    <div className="row">
                      <button
                        className="btn btnSmall"
                        onClick={() => speech.speak(current.de, { lang: "de-DE", rate: 0.96 })}
                        title="Hören"
                      >
                        <Volume2 className="navIcon" /> Hören
                      </button>
                      <button className="btn btnSmall btnGhost" onClick={() => speech.stop()} title="Stop">
                        <XCircle className="navIcon" /> Stop
                      </button>
                    </div>
                  </div>
                </div>
              </div>

              <div className="flashBody">
                <div className="row" style={{ justifyContent: "space-between" }}>
                  <div className="tag">
                    <strong>{currentIndex + 1}</strong>
                    <span>/</span>
                    <strong>{flashList.length}</strong>
                  </div>

                  <div className="tag">
                    <strong>{mastery}%</strong>
                    <span>Meisterung</span>
                  </div>
                </div>

                <div className="teacherSpeech">
